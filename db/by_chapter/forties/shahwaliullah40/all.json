				"url": "https://sunnah.com/bukhari:8"
			}
		},
		{
			"id": 9,
			"idInBook": 9,
			"chapterId": 0,
			"bookId": 12,
			"arabic": "الْحَیَاءُ خَیْرٌ کُلُّهُ",
