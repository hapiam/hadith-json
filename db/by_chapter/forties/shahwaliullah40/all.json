			"reference": {
				"text": "Sahih al-Bukhari 9",
				"url": "https://sunnah.com/bukhari:9"
			}
		},
		{
			"id": 10,
			"idInBook": 10,
			"chapterId": 0,
			"bookId": 12,
			"arabic": "عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ",
			"english": {
				"narrator": "",
				"text": "The word of the believer is like seizing of the hand."
