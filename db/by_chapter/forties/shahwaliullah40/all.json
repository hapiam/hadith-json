			"grade": null,
			"reference": {
				"text": "Sahih al-Bukhari 11",
				"url": "https://sunnah.com/bukhari:11"
			}
		},
		{
			"id": 12,
			"idInBook": 12,
			"chapterId": 0,
			"bookId": 12,
