				"url": "https://sunnah.com/bukhari:6"
			}
		},
		{
			"id": 7,
			"idInBook": 7,
			"chapterId": 0,
			"bookId": 12,
			"arabic": "إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ",
			"english": {
