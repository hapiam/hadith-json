			}
		},
		{
			"id": 5,
			"idInBook": 5,
			"chapterId": 0,
			"bookId": 12,
			"arabic": "الدَّالُّ عَلَی الْخَیْرِ کَفَاعِلِهِ",
			"english": {
				"narrator": "",
				"text": "The person guiding (someone) to do a good deed, is like the one performing the good deed."
