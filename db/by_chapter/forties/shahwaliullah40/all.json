				"url": "https://sunnah.com/bukhari:5"
			}
		},
		{
			"id": 6,
			"idInBook": 6,
			"chapterId": 0,
			"bookId": 12,
			"arabic": "إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ",
