	"hadiths": [
		{
			"id": 41026,
			"idInBook": 1,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَیْسَ الْخَبَرُ کَالْمُعَایَنَةِ",
			"translation": {
				"narrator": "",
				"text": "The report is not like witnessing"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 1, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:1"
			},
			"isAddendum": false
		},
		{
			"id": 41027,
			"idInBook": 2,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْحَرْبُ خُدَعَةٌ",
			"translation": {
				"narrator": "",
				"text": "War is deception"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 2, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:2"
			},
			"isAddendum": false
		},
		{
			"id": 41028,
			"idInBook": 3,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْمُسْلِمُ مِرْآةُ الْمُسْلِمِ",
			"translation": {
				"narrator": "",
				"text": "A Muslim is a mirror of the Muslim"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 3, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:3"
			},
			"isAddendum": false
		},
		{
			"id": 41029,
			"idInBook": 4,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْمُسْتَشَارُ مُؤتَمَنٌ",
			"translation": {
				"narrator": "",
				"text": "Someone whose advice is sought is in a position of trust"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 4, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:4"
			},
			"isAddendum": false
		},
		{
			"id": 41030,
			"idInBook": 5,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الدَّالُّ عَلَی الْخَیْرِ کَفَاعِلِهِ",
			"translation": {
				"narrator": "",
				"text": "The person guiding (someone) to do a good deed, is like the one performing the good deed"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 5, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:5"
			},
			"isAddendum": false
		},
		{
			"id": 41031,
			"idInBook": 6,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ",
			"translation": {
				"narrator": "",
				"text": "Seek help for any needs discreetly"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 6, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:6"
			},
			"isAddendum": false
		},
		{
			"id": 41032,
			"idInBook": 7,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ",
			"translation": {
				"narrator": "",
				"text": "Protect yourself from the fire even with a part of a date"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 7, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:7"
			},
			"isAddendum": false
		},
		{
			"id": 41033,
			"idInBook": 8,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الدُّنْیَا سِجْنُ الْمُؤمِنِ وَ جَنَّةُ الْکَافِرِ",
			"translation": {
				"narrator": "",
				"text": "The world is the believer’s prison and the disbeliever’s paradise"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 8, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:8"
			},
			"isAddendum": false
		},
		{
			"id": 41034,
			"idInBook": 9,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْحَیَاءُ خَیْرٌ کُلُّهُ",
			"translation": {
				"narrator": "",
				"text": "Modesty is entirely good"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 9, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:9"
			},
			"isAddendum": false
		},
		{
			"id": 41035,
			"idInBook": 10,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ",
			"translation": {
				"narrator": "",
				"text": "The word of the believer is like seizing of the hand"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 10, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:10"
			},
			"isAddendum": false
		},
		{
			"id": 41036,
			"idInBook": 11,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَا یَحِلُّ لِمُؤمِنٍ اَنْ یَّجُهْرَ أخَاهُ فَوقَ ثَلَاثَةِ أیَّامٍ",
			"translation": {
				"narrator": "",
				"text": "It is unlawful for a believer to sever relations with his brother for more than three days"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 11, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:11"
			},
			"isAddendum": false
		},
		{
			"id": 41037,
			"idInBook": 12,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَیْسَ مِنَّا مَنْ غَشَّنَا",
			"translation": {
				"narrator": "",
				"text": "He is not one of us who cheats us"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 12, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:12"
			},
			"isAddendum": false
		},
		{
			"id": 41038,
			"idInBook": 13,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "مَا قَلَّ وَكَفَى خَيْرٌ مِمَّا كَثُرَ وَأَلْهَى",
			"translation": {
				"narrator": "",
				"text": "A little that suffices is better than an abundance that distracts"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 13, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:13"
			},
			"isAddendum": false
		},
		{
			"id": 41039,
			"idInBook": 14,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الرَّاجِعُ فِيْ هِبَتِهِ کَالرَّاجِعِ فِيْ قَیْئِهِ",
			"translation": {
				"narrator": "",
				"text": "Someone who takes back his gift is like someone who eats his vomit"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 14, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:14"
			},
			"isAddendum": false
		},
		{
			"id": 41040,
			"idInBook": 15,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْبَلَاءُ مُوَکِّلٌ بِالْمَنْطِقِ",
			"translation": {
				"narrator": "",
				"text": "Affliction comes from (loose) talk"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 15, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:15"
			},
			"isAddendum": false
		},
		{
			"id": 41041,
			"idInBook": 16,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "النَّاسُ کَأسْنَانِ الْمُشْطِ",
			"translation": {
				"narrator": "",
				"text": "People are like the teeth of a comb"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 16, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:16"
			},
			"isAddendum": false
		},
		{
			"id": 41042,
			"idInBook": 17,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْغِنَى غِنَى النَّفْسِ",
			"translation": {
				"narrator": "",
				"text": "Richness lies in the richness of the soul"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 17, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:17"
			},
			"isAddendum": false
		},
		{
			"id": 41043,
			"idInBook": 18,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْسَّعِیْدُ مَنْ وُّعِظَ بِغَیْرِهِ",
			"translation": {
				"narrator": "",
				"text": "The felicitous person takes lessons from (the actions of) others"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 18, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:18"
			},
			"isAddendum": false
		},
		{
			"id": 41044,
			"idInBook": 19,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "وَ إِنَّ مِنَ الشِّعْرِ لَحِکْمَةً وَاِنَّ مِنَ الْبَیَانِ لَسِحْرًا",
			"translation": {
				"narrator": "",
				"text": "Indeed, in poetry there is wisdom and in eloquence there is magic"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 19, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:19"
			},
			"isAddendum": false
		},
		{
			"id": 41045,
			"idInBook": 20,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "عَفْوُ الْمُلُوْكِ إِبْقَاءٌ لِلْمُلْكِ",
			"translation": {
				"narrator": "",
				"text": "The king’s pardon preserves the kingdom"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 20, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:20"
			},
			"isAddendum": false
		},
		{
			"id": 41046,
			"idInBook": 21,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اَلْمَرْءُ مَعَ مَنْ أَحَبَّ",
			"translation": {
				"narrator": "",
				"text": "A man will be with whom he loves"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 21, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:21"
			},
			"isAddendum": false
		},
		{
			"id": 41047,
			"idInBook": 22,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "مَا هَلَكَ إمْرُؤٌ عَرَفَ قَدْرَهُ",
			"translation": {
				"narrator": "",
				"text": "A man who knows his worth will not be ruined"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 22, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:22"
			},
			"isAddendum": false
		},
		{
			"id": 41048,
			"idInBook": 23,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اَلْوَلَدُ لِلْفِرَاشِ وَ لِلْعَاهِرِ الْحَجَرُ",
			"translation": {
				"narrator": "",
				"text": "The child belongs to the bed and stoning is for the adulterer"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 23, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:23"
			},
			"isAddendum": false
		},
		{
			"id": 41049,
			"idInBook": 24,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْیَدُ الْعُلْیَا خَیْرٌ مِّنَ الْیَدِ السُّفْلَی",
			"translation": {
				"narrator": "",
				"text": "The upper hand is superior to the lower hand"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 24, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:24"
			},
			"isAddendum": false
		},
		{
			"id": 41050,
			"idInBook": 25,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَا شَکَرَ اللهَ مَنْ لَّا یَشْکُرُ النَّاسَ",
			"translation": {
				"narrator": "",
				"text": "He does not thank Allah who does not thank people"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 25, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:25"
			},
			"isAddendum": false
		},
		{
			"id": 41051,
			"idInBook": 26,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "حُبُّكَ الشَّيْءَ یُعْمِيْ وَ یُصِمُّ",
			"translation": {
				"narrator": "",
				"text": "Your love of something can blind and deafen (you)"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 26, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:26"
			},
			"isAddendum": false
		},
		{
			"id": 41052,
			"idInBook": 27,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "جُبِلَتِ الْقُلُوبُ عَلی حُبَّ مَنْ اَحْسَنَ اِلَیْهَا وَ بُغْضِ مَنْ اَسَاءَ اِلَیْهَا",
			"translation": {
				"narrator": "",
				"text": "Hearts are predisposed to love someone who does them good and detest someone who does them harm"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 27, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:27"
			},
			"isAddendum": false
		},
		{
			"id": 41053,
			"idInBook": 28,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْتَّائِبُ مِنَ الذَّنْبِ کَمَنْ لَا ذَنْبَ لَهُ",
			"translation": {
				"narrator": "",
				"text": "One who repents from sin is like someone without sin"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 28, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:28"
			},
			"isAddendum": false
		},
		{
			"id": 41054,
			"idInBook": 29,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الشَّاهِدُ یَرَی مَا لَا یَرَاهُ الْغَائِبُ",
			"translation": {
				"narrator": "",
				"text": "The person who actually witnesses an (event) sees that which one who is absent does not"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 29, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:29"
			},
			"isAddendum": false
		},
		{
			"id": 41055,
			"idInBook": 30,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اِذا جَاءَکُمْ کَرِیْمُ قَوْمٍ فَاَکْرِمُوهُ",
			"translation": {
				"narrator": "",
				"text": "If the nobleman of a people comes to you, honour him"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 30, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:30"
			},
			"isAddendum": false
		},
		{
			"id": 41056,
			"idInBook": 31,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْیَمِینُ الْفَاجِرَةُ تَدَعُ الدِّیَارَ الْبَلَاقِعَ",
