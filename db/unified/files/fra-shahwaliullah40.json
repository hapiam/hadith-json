	"hadiths": [
		{
			"id": 41026,
			"idInBook": 1,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَیْسَ الْخَبَرُ کَالْمُعَایَنَةِ",
			"translation": {
				"narrator": "",
				"text": "La nouvelle (rapportée) n’est pas comme ce qu’on voit (de ses propres yeux)"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 1, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:1"
			},
			"isAddendum": false
		},
		{
			"id": 41027,
			"idInBook": 2,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْحَرْبُ خُدَعَةٌ",
			"translation": {
				"narrator": "",
				"text": "La guerre est tromperie"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 2, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:2"
			},
			"isAddendum": false
		},
		{
			"id": 41028,
			"idInBook": 3,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْمُسْلِمُ مِرْآةُ الْمُسْلِمِ",
			"translation": {
				"narrator": "",
				"text": "Le musulman est le miroir du musulman"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 3, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:3"
			},
			"isAddendum": false
		},
		{
			"id": 41029,
			"idInBook": 4,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْمُسْتَشَارُ مُؤتَمَنٌ",
			"translation": {
				"narrator": "",
				"text": "Celui à qui l’on demande conseil est dépositaire d’une confiance"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 4, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:4"
			},
			"isAddendum": false
		},
		{
			"id": 41030,
			"idInBook": 5,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الدَّالُّ عَلَی الْخَیْرِ کَفَاعِلِهِ",
			"translation": {
				"narrator": "",
				"text": "Celui qui guide vers une bonne action est comme celui qui l’accomplit"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 5, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:5"
			},
			"isAddendum": false
		},
		{
			"id": 41031,
			"idInBook": 6,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ",
			"translation": {
				"narrator": "",
				"text": "Cherchez à satisfaire vos besoins discrètement"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 6, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:6"
			},
			"isAddendum": false
		},
		{
			"id": 41032,
			"idInBook": 7,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ",
			"translation": {
				"narrator": "",
				"text": "Préserve-toi du Feu, ne serait-ce qu’avec une moitié de datte"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 7, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:7"
			},
			"isAddendum": false
		},
		{
			"id": 41033,
			"idInBook": 8,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الدُّنْیَا سِجْنُ الْمُؤمِنِ وَ جَنَّةُ الْکَافِرِ",
			"translation": {
				"narrator": "",
				"text": "Ce bas monde est la prison du croyant et le paradis du mécréant"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 8, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:8"
			},
			"isAddendum": false
		},
		{
			"id": 41034,
			"idInBook": 9,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْحَیَاءُ خَیْرٌ کُلُّهُ",
			"translation": {
				"narrator": "",
				"text": "La pudeur n’apporte que du bien"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 9, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:9"
			},
			"isAddendum": false
		},
		{
			"id": 41035,
			"idInBook": 10,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ",
			"translation": {
				"narrator": "",
				"text": "La parole du croyant est ferme comme une poigne de main"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 10, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:10"
			},
			"isAddendum": false
		},
		{
			"id": 41036,
			"idInBook": 11,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَا یَحِلُّ لِمُؤمِنٍ اَنْ یَّجُهْرَ أخَاهُ فَوقَ ثَلَاثَةِ أیَّامٍ",
			"translation": {
				"narrator": "",
				"text": "Il est interdit au croyant de couper les liens avec son frère plus de trois jours"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 11, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:11"
			},
			"isAddendum": false
		},
		{
			"id": 41037,
			"idInBook": 12,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَیْسَ مِنَّا مَنْ غَشَّنَا",
			"translation": {
				"narrator": "",
				"text": "N’est pas des nôtres celui qui nous trompe"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 12, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:12"
			},
			"isAddendum": false
		},
		{
			"id": 41038,
			"idInBook": 13,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "مَا قَلَّ وَكَفَى خَيْرٌ مِمَّا كَثُرَ وَأَلْهَى",
			"translation": {
				"narrator": "",
				"text": "Un peu qui suffit vaut mieux qu’une abondance qui détourne"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 13, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:13"
			},
			"isAddendum": false
		},
		{
			"id": 41039,
			"idInBook": 14,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الرَّاجِعُ فِيْ هِبَتِهِ کَالرَّاجِعِ فِيْ قَیْئِهِ",
			"translation": {
				"narrator": "",
				"text": "Celui qui reprend son cadeau est comme celui qui mange son vomi"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 14, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:14"
			},
			"isAddendum": false
		},
		{
			"id": 41040,
			"idInBook": 15,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْبَلَاءُ مُوَکِّلٌ بِالْمَنْطِقِ",
			"translation": {
				"narrator": "",
				"text": "Les malheurs viennent souvent des paroles déplacées"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 15, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:15"
			},
			"isAddendum": false
		},
		{
			"id": 41041,
			"idInBook": 16,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "النَّاسُ کَأسْنَانِ الْمُشْطِ",
			"translation": {
				"narrator": "",
				"text": "Les gens sont (égaux) comme les dents d’un peigne"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 16, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:16"
			},
			"isAddendum": false
		},
		{
			"id": 41042,
			"idInBook": 17,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْغِنَى غِنَى النَّفْسِ",
			"translation": {
				"narrator": "",
				"text": "La vraie richesse est la richesse du cœur"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 17, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:17"
			},
			"isAddendum": false
		},
		{
			"id": 41043,
			"idInBook": 18,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْسَّعِیْدُ مَنْ وُّعِظَ بِغَیْرِهِ",
			"translation": {
				"narrator": "",
				"text": "L’homme heureux est celui qui tire des leçons de ce que vivent les autres"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 18, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:18"
			},
			"isAddendum": false
		},
		{
			"id": 41044,
			"idInBook": 19,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "وَ إِنَّ مِنَ الشِّعْرِ لَحِکْمَةً وَاِنَّ مِنَ الْبَیَانِ لَسِحْرًا",
			"translation": {
				"narrator": "",
				"text": "Il y a certes de la sagesse dans la poésie, et une magie dans l’éloquence"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 19, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:19"
			},
			"isAddendum": false
		},
		{
			"id": 41045,
			"idInBook": 20,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "عَفْوُ الْمُلُوْكِ إِبْقَاءٌ لِلْمُلْكِ",
			"translation": {
				"narrator": "",
				"text": "Le pardon du roi protège le royaume"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 20, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:20"
			},
			"isAddendum": false
		},
		{
			"id": 41046,
			"idInBook": 21,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اَلْمَرْءُ مَعَ مَنْ أَحَبَّ",
			"translation": {
				"narrator": "",
				"text": "L’homme sera avec ceux qu’il aime"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 21, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:21"
			},
			"isAddendum": false
		},
		{
			"id": 41047,
			"idInBook": 22,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "مَا هَلَكَ إمْرُؤٌ عَرَفَ قَدْرَهُ",
			"translation": {
				"narrator": "",
				"text": "Celui qui connaît sa valeur ne se perd pas"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 22, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:22"
			},
			"isAddendum": false
		},
		{
			"id": 41048,
			"idInBook": 23,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اَلْوَلَدُ لِلْفِرَاشِ وَ لِلْعَاهِرِ الْحَجَرُ",
			"translation": {
				"narrator": "",
				"text": "L’enfant est attribué au lit (du mariage), et la lapidation pour l’adultère"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 23, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:23"
			},
			"isAddendum": false
		},
		{
			"id": 41049,
			"idInBook": 24,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْیَدُ الْعُلْیَا خَیْرٌ مِّنَ الْیَدِ السُّفْلَی",
			"translation": {
				"narrator": "",
				"text": "La main qui donne est meilleure que celle qui reçoit"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 24, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:24"
			},
			"isAddendum": false
		},
		{
			"id": 41050,
			"idInBook": 25,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "لَا شَکَرَ اللهَ مَنْ لَّا یَشْکُرُ النَّاسَ",
			"translation": {
				"narrator": "",
				"text": "Celui qui ne remercie pas les gens ne remercie pas Allah"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 25, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:25"
			},
			"isAddendum": false
		},
		{
			"id": 41051,
			"idInBook": 26,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "حُبُّكَ الشَّيْءَ یُعْمِيْ وَ یُصِمُّ",
			"translation": {
				"narrator": "",
				"text": "L’amour pour une chose peut rendre aveugle et sourd"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 26, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:26"
			},
			"isAddendum": false
		},
		{
			"id": 41052,
			"idInBook": 27,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "جُبِلَتِ الْقُلُوبُ عَلی حُبَّ مَنْ اَحْسَنَ اِلَیْهَا وَ بُغْضِ مَنْ اَسَاءَ اِلَیْهَا",
			"translation": {
				"narrator": "",
				"text": "Les cœurs sont naturellement portés à aimer celui qui leur fait du bien, et à détester celui qui leur fait du mal"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 27, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:27"
			},
			"isAddendum": false
		},
		{
			"id": 41053,
			"idInBook": 28,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْتَّائِبُ مِنَ الذَّنْبِ کَمَنْ لَا ذَنْبَ لَهُ",
			"translation": {
				"narrator": "",
				"text": "Celui qui se repent du péché est comme s’il n’avait jamais péché"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 28, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:28"
			},
			"isAddendum": false
		},
		{
			"id": 41054,
			"idInBook": 29,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الشَّاهِدُ یَرَی مَا لَا یَرَاهُ الْغَائِبُ",
			"translation": {
				"narrator": "",
				"text": "Celui qui assiste à un événement voit ce que l’absent ne voit pas"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 29, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:29"
			},
			"isAddendum": false
		},
		{
			"id": 41055,
			"idInBook": 30,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "اِذا جَاءَکُمْ کَرِیْمُ قَوْمٍ فَاَکْرِمُوهُ",
			"translation": {
				"narrator": "",
				"text": "Si un noble d’un peuple vient vers vous, honorez-le"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 30, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:30"
			},
			"isAddendum": false
		},
		{
			"id": 41056,
			"idInBook": 31,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْیَمِینُ الْفَاجِرَةُ تَدَعُ الدِّیَارَ الْبَلَاقِعَ",
			"translation": {
				"narrator": "",
				"text": "Les faux serments détruisent les foyers"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 31, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:31"
			},
			"isAddendum": false
		},
		{
			"id": 41057,
			"idInBook": 32,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "مَنْ قُتِلَ دُونَ مَالِهِ فَهُوَ شَهِیْدٌ",
			"translation": {
				"narrator": "",
				"text": "Celui qui meurt en défendant ses biens est martyr"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 32, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:32"
			},
			"isAddendum": false
		},
		{
			"id": 41058,
			"idInBook": 33,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "الْاَعْمَالُ بِالنِّیَّةِ",
			"translation": {
				"narrator": "",
				"text": "Les actions ne valent que par les intentions"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 33, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:33"
			},
			"isAddendum": false
		},
		{
			"id": 41059,
			"idInBook": 34,
			"chapterId": 1,
			"bookId": 12,
			"arabic": "سَیِّدُ الْقَوْمِ خَادِمُهُمْ",
			"translation": {
				"narrator": "",
				"text": "Le chef d’un peuple est leur serviteur"
			},
			"grades": [],
			"reference": {
				"text": "Hadith 34, 40 Hadith Shah Waliullah",
				"url": "https://sunnah.com/shahwaliullah40:34"
			},
			"isAddendum": false
