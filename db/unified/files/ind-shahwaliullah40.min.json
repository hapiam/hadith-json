ttps://sunnah.com/shahwaliullah40:5"},"isAddendum":false},{"id":41031,"idInBook":6,"chapterId":0,"bookId":12,"arabic":"إِسْتَعِیْنُوْا عَلَی الْحَوَائِجِ بِالْکِتْمَانِ","translation":{"narrator":"","text":"Carilah bantuan untuk segala kebutuhan secara diam-diam.","status":"draft"},"grades":[],"reference":{"text":"Hadith 6, 40 Hadith Shah Waliullah","url":"https://sunnah.com/shahwaliullah40:6"},"isAddendum":false},{"id":41032,"idInBook":7,"chapterId":0,"bookId":12,"arabic":"إِتَّقُوْا النَّارَ وَلَوْ بِشِقِّ تَمْرَةٍ","translation":{"narrator":"","text":"Lindungi diri Anda dari api bahkan dengan bagian dari kencan.","status":"draft"},"grades":[],"reference":{"text":"Hadith 7, 40 Hadith Shah Waliullah","url":"https://sunnah.com/shahwaliullah40:7"},"isAddendum":false},{"id":41033,"idInBook":8,"chapterId":0,"bookId":12,"arabic":"الدُّنْیَا سِجْنُ الْمُؤمِنِ وَ جَنَّةُ الْکَافِرِ","translation":{"narrator":"","text":"Dunia adalah penjaranya orang beriman dan surganya orang kafir.","status":"draft"},"grades":[],"reference":{"text":"Hadith 8, 40 Hadith Shah Waliullah","url":"https://sunnah.com/shahwaliullah40:8"},"isAddendum":false},{"id":41034,"idInBook":9,"chapterId":0,"bookId":12,"arabic":"الْحَیَاءُ خَیْرٌ کُلُّهُ","translation":{"narrator":"","text":"Kesopanan sepenuhnya baik.","status":"draft"},"grades":[],"reference":{"text":"Hadith 9, 40 Hadith Shah Waliullah","url":"https://sunnah.com/shahwaliullah40:9"},"isAddendum":false},{"id":41035,"idInBook":10,"chapterId":0,"bookId":12,"arabic":"عِدَةُ الْمُؤمِنِ کَاَخْذِ الْکَفِّ","translation":{"narrator":"","text":"Perkataan orang mukmin itu seperti menggenggam tangan.","status":"draft"},"grades":[],"reference":{"text":"Hadith 10, 40 Hadith Shah Waliullah","url":"https://sunnah.com/shahwaliullah40:10"},"isAddendum":false},{"id":41036,"idInBook":11,"chapterId":0,"bookId":12,"arabic":"لَا یَحِلُّ لِمُؤمِنٍ اَنْ یَّجُهْرَ أخَاهُ فَوقَ ثَلَاثَةِ أیَّامٍ","translation":{"narrator":"","text":"Haram hukumnya bagi seorang mukmin